# Virtual environments
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Python packaging / editable-install artifacts
*.egg-info/
*.egg
build/
dist/
pip-wheel-metadata/

# Dev tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.ipynb_checkpoints/

# Secrets / local env
.env
.env.local
.env.*.local

# Model files (too large for git)
*.safetensors
*.ckpt
*.pt
*.pth
*.bin
*.onnx
models/

# Training data (too large for git)
training_data/processed/
training_data/raw/
training_data/model_output/
training_data/logs/

# ComfyUI and Kohya (separate git repos)
ComfyUI/
kohya_ss/

# System files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.code-workspace

# Temporary files
tmp/
temp/
*.tmp
*.log

# Outputs
outputs/
logs/

# GUI dry-run previews (per-project 256px thumbnails from `trainer prep --dry-run`)
preview/

# GUI recent-projects MRU cache (lives next to the projects root)
.recent_projects.json

# Per-user settings (Wan2GP install path, future per-user prefs).
# Lives next to the projects root; absolute paths are machine-specific.
.user_settings.json

# Shared community LoRA library (sits under projects-root/shared_loras/).
# Defensive — if anyone ever creates one at the repo root, .safetensors
# below already excludes the contents but the empty dir would still get
# tracked.
shared_loras/

# Per-project video pipeline scratch space — extracted frames, upscaled
# frames, RIFE-interpolated frames, raw + final mp4. Intermediate files
# can be hundreds of MB to multi-GB per run.
video/

# Wan2GP install (default lives at ~/Apps/wan2gp/ outside the repo, but
# defensive in case someone clones it inside).
Wan2GP/

# Local launcher shortcut (hardcoded absolute paths, machine-specific)
image_trainer.desktop
